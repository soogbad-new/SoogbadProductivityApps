<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/boldButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        style="?attr/materialIconButtonStyle"
        android:text="B"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="@color/white"
        android:backgroundTint="@color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/italicButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        style="?attr/materialIconButtonStyle"
        android:text="I"
        android:textStyle="italic"
        android:textSize="18sp"
        android:textColor="@color/white"
        android:backgroundTint="@color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toRightOf="@id/boldButton" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/underlineButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        style="?attr/materialIconButtonStyle"
        android:text="U"
        android:textSize="18sp"
        android:textColor="@color/white"
        android:backgroundTint="@color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toRightOf="@id/italicButton" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/textSizeButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        style="?attr/materialIconButtonStyle"
        android:text="Aa"
        android:textSize="16sp"
        android:textColor="@color/white"
        android:backgroundTint="@color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toRightOf="@id/underlineButton" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/textColorButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        style="?attr/materialIconButtonStyle"
        android:text="C"
        android:textSize="18sp"
        android:textColor="@color/white"
        android:backgroundTint="@color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toRightOf="@id/textSizeButton" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/bulletListButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        style="?attr/materialIconButtonStyle"
        android:text="•"
        android:textSize="20sp"
        android:textColor="@color/white"
        android:backgroundTint="@color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toRightOf="@id/textColorButton" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/textAlignmentButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        style="?attr/materialIconButtonStyle"
        android:text="≡"
        android:textSize="20sp"
        android:textColor="@color/white"
        android:backgroundTint="@color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toRightOf="@id/bulletListButton" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/hyperlinkButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        style="?attr/materialIconButtonStyle"
        android:text="🔗"
        android:textSize="18sp"
        android:textColor="@color/white"
        android:backgroundTint="@color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toRightOf="@id/textAlignmentButton" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/regionButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        style="?attr/materialIconButtonStyle"
        android:text="▼"
        android:textSize="14sp"
        android:textColor="@color/white"
        android:backgroundTint="@color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toRightOf="@id/hyperlinkButton" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/undoButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        style="?attr/materialIconButtonStyle"
        android:text="↰"
        android:textSize="20sp"
        android:textColor="@color/white"
        android:backgroundTint="@color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toRightOf="@id/regionButton" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/redoButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        style="?attr/materialIconButtonStyle"
        android:text="↱"
        android:textSize="20sp"
        android:textColor="@color/white"
        android:backgroundTint="@color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toRightOf="@id/undoButton" />

</merge>
