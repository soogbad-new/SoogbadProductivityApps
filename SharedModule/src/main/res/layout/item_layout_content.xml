<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:tools="http://schemas.android.com/tools">

    <com.soogbad.sharedmodule.RichEditText
        android:id="@+id/contentEditText"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/almostBlack"
        android:textSize="16dp"
        android:textColor="@color/white"
        android:gravity="top"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/formattingToolbar"
        app:layout_constraintLeft_toLeftOf="parent"
        tools:ignore="SpUsage">
    </com.soogbad.sharedmodule.RichEditText>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/formattingToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent">

        <Button
            android:id="@+id/boldButton"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:text="B"
            android:textSize="24sp"
            android:textColor="@color/white"
            android:backgroundTint="@color/black"
            android:scaleType="centerCrop"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintLeft_toLeftOf="parent">
        </Button>

        <Button
            android:id="@+id/italicButton"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:text="I"
            android:textSize="24sp"
            android:textColor="@color/white"
            android:backgroundTint="@color/black"
            android:scaleType="centerCrop"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintLeft_toRightOf="@id/boldButton">
        </Button>

        <Button
            android:id="@+id/underlineButton"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:text="U"
            android:textSize="24sp"
            android:backgroundTint="@color/black"
            android:textColor="@color/white"
            android:scaleType="centerCrop"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintLeft_toRightOf="@id/italicButton">
        </Button>

        <Button
            android:id="@+id/textSizeButton"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:text="Aa"
            android:inputType="text"
            android:textSize="22sp"
            android:textColor="@color/white"
            android:backgroundTint="@color/black"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintLeft_toRightOf="@id/underlineButton">
        </Button>

        <Button
            android:id="@+id/textColorButton"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:text="C"
            android:textSize="24sp"
            android:textColor="@color/white"
            android:backgroundTint="@color/black"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintLeft_toRightOf="@id/textSizeButton">
        </Button>

        <Button
            android:id="@+id/bulletListButton"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:text="*"
            android:textSize="24sp"
            android:textColor="@color/white"
            android:backgroundTint="@color/black"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintLeft_toRightOf="@id/textColorButton">
        </Button>

        <Button
            android:id="@+id/alignmentButton"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:text="L"
            android:textSize="24sp"
            android:textColor="@color/white"
            android:backgroundTint="@color/black"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintLeft_toRightOf="@id/bulletListButton">
        </Button>

        <Button
            android:id="@+id/hyperlinkButton"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:text="🔗"
            android:textSize="24sp"
            android:textColor="@color/white"
            android:backgroundTint="@color/black"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintLeft_toRightOf="@id/alignmentButton">
        </Button>

    </androidx.constraintlayout.widget.ConstraintLayout>

</merge>
