<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:tools="http://schemas.android.com/tools">

    <com.soogbad.sharedmodule.RichEditText
        android:id="@+id/contentEditText"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@color/almostBlack"
        android:textSize="18dp"
        android:textColor="@color/white"
        android:gravity="top"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/formattingToolbarScrollView"
        app:layout_constraintLeft_toLeftOf="parent"
        tools:ignore="SpUsage" />

    <HorizontalScrollView
        android:id="@+id/formattingToolbarScrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/formattingToolbar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <include layout="@layout/formatting_toolbar_content" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </HorizontalScrollView>

</merge>
